{"name":"Веб-разработк (Dynamic)","settings":"{\"settings\":\"{\\n  // ==================== ИНТЕРФЕЙС И ТЕМА ====================\\n  \\\"workbench.colorTheme\\\": \\\"Webstorm New Dark\\\",\\n  \\\"workbench.iconTheme\\\": \\\"vscode-jetbrains-icon-theme-2023-dark\\\",\\n  \\\"editor.fontFamily\\\": \\\"JetBrains Mono, Fira Code, 'Cascadia Code', Consolas, monospace\\\",\\n  \\\"editor.fontLigatures\\\": false,\\n  \\\"editor.fontSize\\\": 12.5,\\n  \\\"editor.lineHeight\\\": 1.5,\\n  \\\"editor.minimap.enabled\\\": true,\\n  \\\"editor.minimap.renderCharacters\\\": false,\\n  \\\"editor.minimap.maxColumn\\\": 80,\\n\\n  // ==================== РАЗНОЦВЕТНЫЕ СКОБКИ ====================\\n  \\\"editor.bracketPairColorization.enabled\\\": true,\\n  \\\"workbench.colorCustomizations\\\": {\\n    \\\"editorBracketHighlight.foreground1\\\": \\\"#FFB86C\\\",\\n    \\\"editorBracketHighlight.foreground2\\\": \\\"#62D6E8\\\",\\n    \\\"editorBracketHighlight.foreground3\\\": \\\"#BD93F9\\\",\\n    \\\"editorBracketHighlight.foreground4\\\": \\\"#F1FA8C\\\",\\n    \\\"editorBracketHighlight.foreground5\\\": \\\"#FF79C6\\\",\\n    \\\"editorBracketHighlight.foreground6\\\": \\\"#8bfdbe\\\",\\n  },\\n  \\\"editor.guides.bracketPairs\\\": \\\"active\\\",\\n\\n  // ==================== ФОРМАТИРОВАНИЕ (PRETTIER) ====================\\n  \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  \\\"editor.formatOnSave\\\": true,\\n  \\\"prettier.singleQuote\\\": true,\\n  \\\"prettier.semi\\\": true,\\n  \\\"prettier.tabWidth\\\": 2,\\n  \\\"prettier.useTabs\\\": false,\\n  \\\"prettier.trailingComma\\\": \\\"es5\\\",\\n  \\\"prettier.printWidth\\\": 120,\\n  \\\"prettier.jsxSingleQuote\\\": false,\\n  \\\"prettier.bracketSameLine\\\": false,\\n\\n  // ==================== ОТКЛЮЧЕНИЕ PRETTIER ДЛЯ НЕКОТОРЫХ ЯЗЫКОВ ====================\\n  \\\"[markdown]\\\": {\\n    \\\"editor.defaultFormatter\\\": null,\\n    \\\"editor.formatOnSave\\\": false,\\n  },\\n  \\\"[sql]\\\": {\\n    \\\"editor.defaultFormatter\\\": null,\\n    \\\"editor.formatOnSave\\\": false,\\n  },\\n  \\\"[mysql]\\\": {\\n    \\\"editor.defaultFormatter\\\": null,\\n    \\\"editor.formatOnSave\\\": false,\\n  },\\n  \\\"[plsql]\\\": {\\n    \\\"editor.defaultFormatter\\\": null,\\n    \\\"editor.formatOnSave\\\": false,\\n  },\\n  \\\"[rust]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"rust-lang.rust-analyzer\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n  },\\n  \\\"[toml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"tamasfe.even-better-toml\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n  },\\n\\n  // ==================== ЛИНТИНГ (ESLINT) ====================\\n  \\\"eslint.validate\\\": [\\\"javascript\\\", \\\"javascriptreact\\\", \\\"typescript\\\", \\\"typescriptreact\\\"],\\n  \\\"eslint.run\\\": \\\"onSave\\\",\\n  \\\"eslint.format.enable\\\": true,\\n  \\\"eslint.codeAction.showDocumentation\\\": {\\n    \\\"enable\\\": true,\\n  },\\n\\n  // ==================== TAILWIND CSS ====================\\n  \\\"tailwindCSS.includeLanguages\\\": {\\n    \\\"javascript\\\": \\\"javascript\\\",\\n    \\\"javascriptreact\\\": \\\"javascriptreact\\\",\\n    \\\"typescript\\\": \\\"typescript\\\",\\n    \\\"typescriptreact\\\": \\\"typescriptreact\\\",\\n  },\\n  \\\"tailwindCSS.experimental.classRegex\\\": [\\n    [\\\"clsx\\\\\\\\(([^)]*)\\\\\\\\)\\\", \\\"'([^']*)'\\\"],\\n    [\\\"cn\\\\\\\\(([^)]*)\\\\\\\\)\\\", \\\"'([^']*)'\\\"],\\n  ],\\n  \\\"editor.quickSuggestions\\\": {\\n    \\\"strings\\\": true,\\n  },\\n\\n  // ==================== РАБОТА С ТЕГАМИ ====================\\n  \\\"html.autoClosingTags\\\": false,\\n  \\\"auto-close-tag.SublimeText3Mode\\\": true,\\n  \\\"auto-close-tag.activationOnLanguage\\\": [\\n    \\\"html\\\",\\n    \\\"xml\\\",\\n    \\\"javascript\\\",\\n    \\\"javascriptreact\\\",\\n    \\\"typescript\\\",\\n    \\\"typescriptreact\\\",\\n  ],\\n  \\\"editor.linkedEditing\\\": true,\\n\\n  // ==================== ПРОВЕРКА ОРФОГРАФИИ ====================\\n  \\\"cSpell.language\\\": \\\"en,ru\\\",\\n  \\\"cSpell.enabled\\\": true,\\n  \\\"cSpell.enabledFileTypes\\\": {\\n    \\\"html\\\": true,\\n    \\\"css\\\": true,\\n    \\\"javascript\\\": true,\\n    \\\"json\\\": true,\\n    \\\"markdown\\\": true,\\n    \\\"sql\\\": true,\\n    \\\"rust\\\": false,\\n    \\\"toml\\\": true,\\n  },\\n  \\\"cSpell.words\\\": [\\\"const\\\", \\\"typeof\\\", \\\"instanceof\\\"],\\n\\n  // ==================== RUST-ANALYZER ====================\\n  \\\"rust-analyzer.procMacro.enable\\\": true,\\n  \\\"rust-analyzer.checkOnSave\\\": true,\\n  \\\"rust-analyzer.inlayHints.typeHints.enable\\\": true,\\n  \\\"rust-analyzer.inlayHints.parameterHints.enable\\\": true,\\n  \\\"rust-analyzer.inlayHints.chainingHints.enable\\\": true,\\n\\n  // ==================== CODELLDB (ОТЛАДЧИК) ====================\\n  \\\"lldb.displayFormat\\\": \\\"auto\\\",\\n  \\\"lldb.showDisassembly\\\": \\\"never\\\",\\n  \\\"lldb.dereferencePointers\\\": true,\\n  \\\"lldb.consoleMode\\\": \\\"commands\\\",\\n\\n  // ==================== EVEN BETTER TOML ====================\\n  \\\"evenBetterToml.formatter.alignEntries\\\": true,\\n  \\\"evenBetterToml.formatter.arrayAutoCollapse\\\": true,\\n  \\\"evenBetterToml.formatter.arrayAutoExpand\\\": false,\\n  \\\"evenBetterToml.formatter.columnWidth\\\": 80,\\n\\n  // ==================== DEPENDI (Управление зависимостями) ====================\\n  \\\"dependi.vulnerability.enabled\\\": true,\\n\\n  // ==================== TAURI ====================\\n  \\\"json.schemas\\\": [\\n    {\\n      \\\"fileMatch\\\": [\\\"tauri.conf.json\\\"],\\n      \\\"url\\\": \\\"https://json.schemastore.org/tauri.json\\\",\\n    },\\n  ],\\n\\n  // ==================== ТЕРМИНАЛ ====================\\n  \\\"terminal.integrated.defaultProfile.windows\\\": \\\"Command Prompt\\\",\\n  \\\"terminal.integrated.fontSize\\\": 13,\\n\\n  // ==================== VITEST ====================\\n  \\\"testing.automaticallyOpenPeekView\\\": \\\"never\\\",\\n\\n  // ==================== ПРОБЕЛЫ В КОНЦЕ СТРОК ====================\\n  \\\"files.trimTrailingWhitespace\\\": true,\\n  \\\"trailing-spaces.trimOnSave\\\": true,\\n\\n  // ==================== ПОИСК И ИСКЛЮЧЕНИЯ ====================\\n  \\\"search.exclude\\\": {\\n    \\\"**/target\\\": true,\\n    \\\"**/node_modules\\\": true,\\n  },\\n  \\\"files.watcherExclude\\\": {\\n    \\\"**/target\\\": true,\\n    \\\"**/node_modules\\\": true,\\n  },\\n\\n  // ==================== ПРОЧЕЕ ====================\\n  \\\"editor.autoClosingBrackets\\\": \\\"always\\\",\\n  \\\"editor.renderWhitespace\\\": \\\"selection\\\",\\n}\\n\"}","extensions":"[{\"identifier\":{\"id\":\"antfu.browse-lite\",\"uuid\":\"61ce9ab3-f230-47ea-8cdc-2b5eb25f3ae2\"},\"displayName\":\"Browse Lite\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"antfu.vite\",\"uuid\":\"b22eea9f-5a30-43a2-8a59-3d3707869cf8\"},\"displayName\":\"Vite\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"bradlc.vscode-tailwindcss\",\"uuid\":\"4db62a7c-7d70-419c-96d2-6c3a4dc77ea5\"},\"displayName\":\"Tailwind CSS IntelliSense\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"chadalen.vscode-jetbrains-icon-theme\",\"uuid\":\"641f0c25-0eca-440e-bcf8-8d36d9f23044\"},\"displayName\":\"JetBrains Icon Theme\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"dbaeumer.vscode-eslint\",\"uuid\":\"583b2b34-2c1e-4634-8c0b-0b82e283ea3a\"},\"displayName\":\"ESLint\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"dsznajder.es7-react-js-snippets\",\"uuid\":\"19804510-b475-4dae-b0f7-6ca08fd1af0c\"},\"displayName\":\"ES7+ React/Redux/React-Native snippets\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"eenaree.webstorm-new-dark\",\"uuid\":\"5274c722-6166-4b27-bc86-65f2f832d8de\"},\"displayName\":\"WebStorm New UI Theme\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"esbenp.prettier-vscode\",\"uuid\":\"96fa4707-6983-4489-b7c5-d5ffdfdcce